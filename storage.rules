rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return firestore.get(
        /databases/(default)/documents/users/$(request.auth.uid)
      ).data.role;
    }

    function isAtLeast(minRole) {
      let ranks = { viewer: 1, editor: 2, admin: 3, super_admin: 4 };
      return isSignedIn() && ranks[userRole()] >= ranks[minRole];
    }

    // ── Public content folders — public read, editor+ write, admin+ delete ─────

    match /news/{fileName} {
      allow read:   if true;
      allow create,
            update: if isAtLeast('editor')
                    && request.resource.size < 10 * 1024 * 1024  // 10 MB
                    && request.resource.contentType.matches('image/.*');
      allow delete: if isAtLeast('admin');
    }

    match /staff/{fileName} {
      allow read:   if true;
      allow create,
            update: if isAtLeast('editor')
                    && request.resource.size < 5 * 1024 * 1024   // 5 MB
                    && request.resource.contentType.matches('image/.*');
      allow delete: if isAtLeast('admin');
    }

    match /documents/{fileName} {
      allow read:   if true;
      allow create,
            update: if isAtLeast('editor')
                    && request.resource.size < 50 * 1024 * 1024  // 50 MB
                    && request.resource.contentType == 'application/pdf';
      allow delete: if isAtLeast('admin');
    }

    match /research/{fileName} {
      allow read:   if true;
      allow create,
            update: if isAtLeast('editor')
                    && request.resource.size < 50 * 1024 * 1024
                    && request.resource.contentType == 'application/pdf';
      allow delete: if isAtLeast('admin');
    }

    match /media/{fileName} {
      allow read:   if true;
      allow create,
            update: if isAtLeast('editor')
                    && request.resource.size < 100 * 1024 * 1024 // 100 MB
                    && (request.resource.contentType.matches('image/.*')
                        || request.resource.contentType.matches('video/.*'));
      allow delete: if isAtLeast('admin');
    }

    // ── Private folder — contact form attachments ─────────────────────────────
    // Anyone can upload (contact form); only admin+ can read.

    match /attachments/{fileName} {
      allow read:          if isAtLeast('admin');
      allow create,update: if request.resource.size < 20 * 1024 * 1024
                           && (request.resource.contentType.matches('image/.*')
                               || request.resource.contentType.matches('application/.*'));
      allow delete:        if isAtLeast('admin');
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
